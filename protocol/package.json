{
  "name": "@popcharts/protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./market-side": "./src/market-side.ts",
    "./market-status": "./src/market-status.ts",
    "./pregrad-manager": "./src/generated/pregrad-manager.ts",
    "./postgrad-venue": "./src/generated/postgrad-venue.ts",
    "./mock-collateral": "./src/generated/mock-collateral.ts",
    "./third-party/venue": "./src/generated/third-party/venue.ts",
    "./complete-set-price-policy": "./src/price/completeSetPricePolicy.ts",
    "./tick-to-sqrt-price": "./src/price/tickToSqrtPriceX96.ts",
    "./virtual-lmsr": "./src/price/virtualLmsr.ts"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "hardhat build && node --experimental-strip-types scripts/export-contract-metadata.ts",
    "clean": "hardhat clean",
    "arc:testnet:deploy": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/deploy-arc-protocol.ts",
    "arc:testnet:deploy-mock": "hardhat build && node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js run scripts/deploy-arc-mock.ts",
    "arc:testnet:deploy-venue": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/deploy-venue-stack.ts",
    "arc:testnet:deploy-postgrad": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/deploy-complete-set-postgrad.ts",
    "arc:testnet:create-market": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/create-complete-set-market.ts",
    "arc:testnet:smoke-maker-order": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/smoke-maker-order.ts",
    "arc:testnet:smoke-taker-swap": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/smoke-taker-swap.ts",
    "arc:testnet:smoke-arb": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/smoke-complete-set-arb.ts",
    "arc:testnet:smoke-resolution": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/smoke-resolution.ts",
    "arc:testnet:keeper": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/keeper-complete-set.ts",
    "arc:testnet:cancel-market": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/cancel-market.ts",
    "arc:testnet:inspect-orders": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/inspect-bounded-orders.ts",
    "arc:testnet:check-health": "node --env-file-if-exists=.env ./node_modules/hardhat/dist/src/cli.js --build-profile production --network arcTestnet run scripts/check-market-health.ts",
    "devchain:deploy": "hardhat build && hardhat run scripts/deploy-devchain.ts",
    "devchain:node": "hardhat node",
    "deployment:check-venue": "hardhat deployment check-venue",
    "deployment:write-venue-manifest": "hardhat deployment write-venue-manifest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:sol": "solhint \"contracts/**/*.sol\" \"test/solidity/**/*.sol\"",
    "local:create-market": "hardhat run scripts/create-local-market.ts --network localhost",
    "local:create-complete-set-market": "hardhat run scripts/create-complete-set-market.ts --network localhost",
    "local:deploy-pregrad": "hardhat run scripts/deploy-local-pregrad.ts --network localhost",
    "local:deploy-venue": "hardhat run scripts/deploy-venue-stack.ts --network localhost",
    "local:deploy-postgrad": "hardhat run scripts/deploy-complete-set-postgrad.ts --network localhost",
    "local:smoke-maker-order": "hardhat run scripts/smoke-maker-order.ts --network localhost",
    "local:smoke-taker-swap": "hardhat run scripts/smoke-taker-swap.ts --network localhost",
    "local:smoke-arb": "hardhat run scripts/smoke-complete-set-arb.ts --network localhost",
    "local:smoke-resolution": "hardhat run scripts/smoke-resolution.ts --network localhost",
    "local:smoke-market": "pnpm run local:smoke-maker-order && pnpm run local:smoke-taker-swap && pnpm run local:smoke-arb && pnpm run local:smoke-resolution",
    "local:keeper": "hardhat run scripts/keeper-complete-set.ts --network localhost",
    "local:cancel-market": "hardhat run scripts/cancel-market.ts --network localhost",
    "local:inspect-orders": "hardhat run scripts/inspect-bounded-orders.ts --network localhost",
    "local:check-health": "hardhat run scripts/check-market-health.ts --network localhost",
    "metadata:check": "hardhat build && node --experimental-strip-types scripts/export-contract-metadata.ts --check",
    "operator:postgrad-admin": "hardhat operator",
    "test": "hardhat test",
    "test:coverage": "hardhat test --coverage",
    "test:coverage:ts": "c8 --all --src src --include 'src/**' --exclude 'src/generated/**' --exclude 'src/**/*.d.ts' --reporter=lcov --reporter=text-summary --report-dir coverage-ts hardhat test nodejs",
    "test:nodejs": "hardhat test nodejs",
    "test:solidity": "hardhat test solidity",
    "typecheck": "pnpm metadata:check && tsc --noEmit"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@prb/math": "4.1.2",
    "@uniswap/v4-core": "1.0.2",
    "@uniswap/v4-periphery": "1.0.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "3.1.7",
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@nomicfoundation/ignition-core": "3.1.7",
    "@types/node": "22.19.21",
    "c8": "12.0.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.7",
    "hardhat": "3.9.0",
    "prettier": "3.8.4",
    "prettier-plugin-solidity": "2.3.1",
    "solhint": "6.2.1",
    "typescript": "6.0.3",
    "viem": "2.52.2"
  }
}
