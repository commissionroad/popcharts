{
  "name": "popcharts-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun build src/api/index.ts --outdir dist/api --target bun && bun build src/indexer/index.ts --outdir dist/indexer --target bun && bun build src/ai-review/server.ts --outdir dist/ai-review --target bun && bun build src/ai-review-runner/index.ts --outdir dist/ai-review-runner --target bun && bun build src/ai-resolution/server.ts --outdir dist/ai-resolution --target bun && bun build src/ai-resolution-runner/index.ts --outdir dist/ai-resolution-runner --target bun",
    "bot:trade": "bun run scripts/bot-trade.ts",
    "db:generate": "drizzle-kit generate",
    "db:ensure-local-constraints": "bun run src/db/ensure-local-unique-constraints.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "dev": "bun run dev:api",
    "dev:api": "bun run --watch src/api/index.ts",
    "dev:ai-review": "bun run --watch src/ai-review/server.ts",
    "dev:ai-review-runner": "bun run --watch src/ai-review-runner/index.ts",
    "dev:indexer": "bun run --watch src/indexer/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "nightly:lifecycle": "bun run src/lifecycle-nightly/run.ts",
    "openapi:check": "bun run scripts/generate-openapi.ts --check && bun run scripts/validate-openapi.ts",
    "openapi:generate": "bun run scripts/generate-openapi.ts && bun run scripts/validate-openapi.ts",
    "smoke:ai-review-runner": "bun run src/ai-review-runner/smoke.ts",
    "start:api": "bun run src/api/index.ts",
    "start:keeper": "bun run src/keeper/index.ts",
    "start:ai-review": "bun run src/ai-review/server.ts",
    "start:ai-review-runner": "bun run src/ai-review-runner/index.ts",
    "start:ai-resolution": "bun run src/ai-resolution/server.ts",
    "start:ai-resolution-runner": "bun run src/ai-resolution-runner/index.ts",
    "start:indexer": "bun run src/indexer/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:integration": "bun run src/test-support/require-int-db-url.ts && bun test int.test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.15",
    "@popcharts/protocol": "file:../protocol",
    "@sinclair/typebox": "^0.34.47",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.4.22",
    "postgres": "^3.4.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^9",
    "@types/bun": "^1.3.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8"
  }
}
