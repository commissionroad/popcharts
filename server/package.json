{
  "name": "popcharts-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun build src/api/index.ts --outdir dist/api --target bun && bun build src/indexer/index.ts --outdir dist/indexer --target bun && bun build src/ai-review/server.ts --outdir dist/ai-review --target bun && bun build src/ai-review-runner/index.ts --outdir dist/ai-review-runner --target bun",
    "db:generate": "drizzle-kit generate",
    "db:ensure-local-constraints": "bun run src/db/ensure-local-unique-constraints.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "dev": "bun run dev:api",
    "dev:api": "bun run --watch src/api/index.ts",
    "dev:ai-review": "bun run --watch src/ai-review/server.ts",
    "dev:ai-review-runner": "bun run --watch src/ai-review-runner/index.ts",
    "dev:indexer": "bun run --watch src/indexer/index.ts",
    "smoke:ai-review-runner": "bun run src/ai-review-runner/smoke.ts",
    "start:api": "bun run src/api/index.ts",
    "start:ai-review": "bun run src/ai-review/server.ts",
    "start:ai-review-runner": "bun run src/ai-review-runner/index.ts",
    "start:indexer": "bun run src/indexer/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.15",
    "@sinclair/typebox": "^0.34.47",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.4.22",
    "postgres": "^3.4.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "drizzle-kit": "^0.30.0",
    "typescript": "^6.0.3"
  }
}
