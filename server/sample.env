# Pop Charts server local environment.
#
# Copy this file to server/.env for local API/indexer development.

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/popcharts
PORT=3001
NETWORK=local

# ECS/RDS deployments can use these component values instead of DATABASE_URL.
# DATABASE_HOST=popcharts.cluster-abc123.us-east-1.rds.amazonaws.com
# DATABASE_PORT=5432
# DATABASE_NAME=popcharts
# DATABASE_USER=popcharts
# DATABASE_PASSWORD=...
# DATABASE_SSL=true

# Local Hardhat defaults. Override these for testnet/mainnet.
RPC_HTTP_URL=http://localhost:8545
RPC_WSS_URL=ws://localhost:8545
PREGRAD_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
PREGRAD_MANAGER_DEPLOY_BLOCK=0

# Optional ECS/Kubernetes-style liveness marker for the indexer process.
HEALTH_CHECK_FILE=/tmp/popcharts-indexer-healthy

# Local AI review service. Ollama itself does not browse the web; this service
# collects safe evidence and passes it to the configured local model.
AI_REVIEW_PORT=3002
AI_REVIEW_PROVIDER=ollama
AI_REVIEW_OLLAMA_MODEL=gpt-oss:20b
OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_REVIEW_INTERNET_ACCESS=search
AI_REVIEW_MAX_SEARCH_RESULTS=5
AI_REVIEW_FETCH_SEARCH_RESULTS=false
AI_REVIEW_TIMEOUT_MS=8000
