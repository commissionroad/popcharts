# Pop Charts server local environment.
#
# Copy this file to server/.env for local API/indexer development.

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/popcharts
PORT=3001
NETWORK=arcTestnet

# ECS/RDS deployments can use these component values instead of DATABASE_URL.
# DATABASE_HOST=popcharts.cluster-abc123.us-east-1.rds.amazonaws.com
# DATABASE_PORT=5432
# DATABASE_NAME=popcharts
# DATABASE_USER=popcharts
# DATABASE_PASSWORD=...
# DATABASE_SSL=true

# Arc Testnet defaults. Set NETWORK=local and LOCAL_* values for local Hardhat.
ARC_TESTNET_RPC_HTTP_URL=https://rpc.testnet.arc.network
ARC_TESTNET_RPC_WSS_URL=wss://rpc.testnet.arc.network
ARC_TESTNET_PREGRAD_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
ARC_TESTNET_PREGRAD_MANAGER_DEPLOY_BLOCK=0

# Local development only. Enables /dev endpoints when NETWORK=local.
POPCHARTS_DEV_TOOLS_ENABLED=false

# Internal operator-only endpoint for enqueueing manual AI review jobs.
POPCHARTS_ADMIN_REVIEW_ENABLED=false

# Optional ECS/Kubernetes-style liveness marker for the indexer process.
HEALTH_CHECK_FILE=/tmp/popcharts-indexer-healthy

# Local AI review service. Ollama itself does not browse the web; this service
# collects safe evidence and passes it to the configured local model. Anthropic
# can use Claude's native web_search/web_fetch tools when configured.
AI_REVIEW_PORT=3002
AI_REVIEW_PROVIDER=ollama
AI_REVIEW_OLLAMA_MODEL=gpt-oss:20b
OLLAMA_BASE_URL=http://127.0.0.1:11434
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_REVIEW_ANTHROPIC_MODEL=claude-sonnet-4-6
AI_REVIEW_ANTHROPIC_MAX_OUTPUT_TOKENS=2048
AI_REVIEW_ANTHROPIC_MAX_WEB_SEARCHES=3
AI_REVIEW_ANTHROPIC_MAX_WEB_FETCHES=2
AI_REVIEW_ANTHROPIC_WEB_FETCH_MAX_CONTENT_TOKENS=12000
AI_REVIEW_INTERNET_ACCESS=search
AI_REVIEW_MAX_SEARCH_RESULTS=5
AI_REVIEW_FETCH_SEARCH_RESULTS=false
AI_REVIEW_TIMEOUT_MS=8000
