# Pop Charts server local environment.
#
# Copy this file to server/.env for local API/indexer development.

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/popcharts
PORT=3001
NETWORK=arcTestnet

# ECS/RDS deployments can use these component values instead of DATABASE_URL.
# DATABASE_HOST=popcharts.cluster-abc123.us-east-1.rds.amazonaws.com
# DATABASE_PORT=5432
# DATABASE_NAME=popcharts
# DATABASE_USER=popcharts
# DATABASE_PASSWORD=...
# DATABASE_SSL=true

# Arc Testnet defaults. Set NETWORK=local and LOCAL_* values for local Hardhat.
ARC_TESTNET_RPC_HTTP_URL=https://rpc.testnet.arc.network
ARC_TESTNET_RPC_WSS_URL=wss://rpc.testnet.arc.network
ARC_TESTNET_PREGRAD_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
ARC_TESTNET_PREGRAD_MANAGER_DEPLOY_BLOCK=0

# Local development only. Enables /dev endpoints when NETWORK=local.
POPCHARTS_DEV_TOOLS_ENABLED=false

# Optional ECS/Kubernetes-style liveness marker for the indexer process.
HEALTH_CHECK_FILE=/tmp/popcharts-indexer-healthy
