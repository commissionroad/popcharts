{
  "openapi": "3.0.3",
  "info": {
    "title": "Pop Charts API",
    "description": "Read API for Pop Charts indexed market events.",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Health check",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/version": {
      "get": {
        "operationId": "getVersion",
        "summary": "Get API version",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionInfo"
                }
              }
            }
          }
        }
      }
    },
    "/markets": {
      "get": {
        "operationId": "listMarkets",
        "summary": "List indexed markets",
        "description": "Returns up to 200 markets sorted by latest creation time. Pass an ISO `since` timestamp to fetch markets created after the previous cursor time.",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketList"
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{chainId}/metadata": {
      "post": {
        "operationId": "saveMarketMetadata",
        "summary": "Save off-chain market metadata",
        "description": "Stores human-readable market metadata by chain ID and metadata hash so indexed markets can render their question and resolution context.",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MarketMetadataWrite"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/MarketMetadataWrite"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/MarketMetadataWrite"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketMetadata"
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/admin/markets/{chainId}/{marketId}/review": {
      "post": {
        "operationId": "requestManualAiReview",
        "summary": "Admin-only enqueue market AI review",
        "description": "Disabled unless POPCHARTS_ADMIN_REVIEW_ENABLED=true. Enqueues manual AI review work for the runner; it does not call the AI Review service directly.",
        "tags": [
          "Administration"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "force": {
                    "type": "boolean"
                  },
                  "model": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "provider": {
                    "$ref": "#/components/schemas/AiReviewProvider"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "force": {
                    "type": "boolean"
                  },
                  "model": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "provider": {
                    "$ref": "#/components/schemas/AiReviewProvider"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "force": {
                    "type": "boolean"
                  },
                  "model": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "provider": {
                    "$ref": "#/components/schemas/AiReviewProvider"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManualAiReviewExistingJob"
                }
              }
            }
          },
          "201": {
            "description": "Response for status 201",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManualAiReviewEnqueued"
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Response for status 404",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "409": {
            "description": "Response for status 409",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManualAiReviewConflict"
                }
              }
            }
          }
        }
      }
    },
    "/dev/markets/{chainId}/{marketId}/close": {
      "post": {
        "operationId": "closeDevMarket",
        "summary": "Dev-only close pre-grad market for refunds",
        "description": "Development-only endpoint. Enabled only when POPCHARTS_DEV_TOOLS_ENABLED=true and NETWORK=local. Fast-forwards the local chain to the market graduation deadline, calls PregradManager.markRefundable, and updates the indexed market projection.",
        "tags": [
          "Development"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DevMarketCloseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Response for status 404",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "409": {
            "description": "Response for status 409",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DevMarketCloseIneligible"
                }
              }
            }
          }
        }
      }
    },
    "/dev/markets/{chainId}/{marketId}/graduate": {
      "post": {
        "operationId": "graduateDevMarket",
        "summary": "Dev-only graduate a pre-grad market end to end",
        "description": "Development-only endpoint. Enabled only when POPCHARTS_DEV_TOOLS_ENABLED=true and NETWORK=local. Tops up receipts to the graduation threshold if needed, starts onchain graduation, submits a dev clearing root, jumps the local chain past any configured challenge window, finalizes with the configured postgrad adapter, and claims every receipt so outcome tokens and refunds settle.",
        "tags": [
          "Development"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DevMarketGraduateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Response for status 404",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "409": {
            "description": "Response for status 409",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DevMarketGraduateIneligible"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{chainId}/{marketId}": {
      "get": {
        "operationId": "getMarket",
        "summary": "Get an indexed market",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Market"
                }
              }
            }
          },
          "404": {
            "description": "Response for status 404",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{chainId}/{marketId}/events": {
      "get": {
        "operationId": "listMarketEvents",
        "summary": "Get market chain events",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketCreatedEventList"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{chainId}/{marketId}/receipts": {
      "get": {
        "operationId": "listMarketReceipts",
        "summary": "Get market receipt events",
        "description": "Returns the indexed ReceiptPlaced events for one market ordered oldest first by on-chain sequence, so clients can replay the LMSR price history without touching an RPC provider.",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReceiptPlacedEventList"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{chainId}/{marketId}/graduate": {
      "post": {
        "operationId": "graduateMarket",
        "summary": "Request market graduation",
        "description": "Checks whether an indexed market is eligible for onchain graduation or already finalized. The server does not mark markets graduated; that status is indexed from PregradManager settlement events.",
        "tags": [
          "Graduation"
        ],
        "parameters": [
          {
            "name": "chainId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraduationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Response for status 404",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "409": {
            "description": "Response for status 409",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraduationIneligible"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Health": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "VersionInfo": {
        "type": "object",
        "required": [
          "buildTime",
          "commitSha",
          "network",
          "version"
        ],
        "properties": {
          "buildTime": {
            "type": "string"
          },
          "commitSha": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "AiReviewEvidence": {
        "type": "object",
        "required": [
          "domain",
          "kind",
          "sourceTier",
          "summary",
          "url"
        ],
        "properties": {
          "domain": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "provided_url",
              "search_result",
              "fetched_page"
            ]
          },
          "sourceTier": {
            "$ref": "#/components/schemas/AiReviewSourceTier"
          },
          "summary": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "AiReviewJobStatus": {
        "type": "string",
        "enum": [
          "queued",
          "running",
          "succeeded",
          "retryable_failed",
          "terminal_failed",
          "cancelled"
        ]
      },
      "AiReviewJobTrigger": {
        "type": "string",
        "enum": [
          "automatic",
          "manual",
          "retry"
        ]
      },
      "AiReviewProvider": {
        "type": "string",
        "enum": [
          "anthropic",
          "heuristic",
          "ollama"
        ]
      },
      "AiReviewScores": {
        "type": "object",
        "required": [
          "contentSafety",
          "corroboration",
          "disputeRisk",
          "objectivity",
          "promptInjectionRisk",
          "publicKnowability",
          "sourceQuality"
        ],
        "properties": {
          "contentSafety": {
            "type": "number"
          },
          "corroboration": {
            "type": "number"
          },
          "disputeRisk": {
            "type": "number"
          },
          "objectivity": {
            "type": "number"
          },
          "promptInjectionRisk": {
            "type": "number"
          },
          "publicKnowability": {
            "type": "number"
          },
          "sourceQuality": {
            "type": "number"
          }
        }
      },
      "AiReviewSourceCheck": {
        "type": "object",
        "required": [
          "domain",
          "notes",
          "relevant",
          "sourceTier",
          "url"
        ],
        "properties": {
          "domain": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "relevant": {
            "type": "boolean"
          },
          "sourceTier": {
            "$ref": "#/components/schemas/AiReviewSourceTier"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "AiReviewSourceTier": {
        "type": "string",
        "enum": [
          "primary",
          "major_news",
          "specialist",
          "ugc",
          "suspicious",
          "unreachable",
          "unknown"
        ]
      },
      "AiReviewVerdict": {
        "type": "string",
        "enum": [
          "approve",
          "reject",
          "manual_review"
        ]
      },
      "DevMarketCloseIneligible": {
        "type": "object",
        "required": [
          "message",
          "market",
          "reason",
          "status"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "market": {
            "$ref": "#/components/schemas/Market"
          },
          "reason": {
            "type": "string",
            "enum": [
              "chain_status",
              "wrong_status"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "ineligible"
            ]
          }
        }
      },
      "DevMarketCloseResponse": {
        "type": "object",
        "required": [
          "market",
          "refundAvailable",
          "status"
        ],
        "properties": {
          "market": {
            "$ref": "#/components/schemas/Market"
          },
          "refundAvailable": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "refunded"
            ]
          },
          "transactionHash": {
            "type": "string"
          }
        }
      },
      "DevMarketGraduateIneligible": {
        "type": "object",
        "required": [
          "message",
          "market",
          "reason",
          "status"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "market": {
            "$ref": "#/components/schemas/Market"
          },
          "reason": {
            "type": "string",
            "enum": [
              "adapter_unconfigured",
              "chain_status",
              "past_deadline",
              "wrong_status"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "ineligible"
            ]
          }
        }
      },
      "DevMarketGraduateResponse": {
        "type": "object",
        "required": [
          "market",
          "postgrad",
          "status",
          "summary",
          "transactionHashes"
        ],
        "properties": {
          "market": {
            "$ref": "#/components/schemas/Market"
          },
          "postgrad": {
            "$ref": "#/components/schemas/MarketPostgrad"
          },
          "status": {
            "type": "string",
            "enum": [
              "graduated"
            ]
          },
          "summary": {
            "$ref": "#/components/schemas/GraduationSummary"
          },
          "transactionHashes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "GraduationIneligible": {
        "type": "object",
        "required": [
          "message",
          "market",
          "reason",
          "status",
          "summary"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "market": {
            "$ref": "#/components/schemas/Market"
          },
          "reason": {
            "type": "string",
            "enum": [
              "below_threshold",
              "clearing_pending",
              "onchain_settlement_required",
              "wrong_status"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "ineligible"
            ]
          },
          "summary": {
            "$ref": "#/components/schemas/GraduationSummary"
          }
        }
      },
      "GraduationResponse": {
        "type": "object",
        "required": [
          "market",
          "status",
          "summary"
        ],
        "properties": {
          "market": {
            "$ref": "#/components/schemas/Market"
          },
          "status": {
            "type": "string",
            "enum": [
              "graduated"
            ]
          },
          "summary": {
            "$ref": "#/components/schemas/GraduationSummary"
          }
        }
      },
      "GraduationSummary": {
        "type": "object",
        "required": [
          "completeSetCount",
          "graduatedAt",
          "graduationThreshold",
          "matchedMarketCap",
          "noTokens",
          "receiptCount",
          "refundedCollateral",
          "totalEscrowed",
          "yesTokens"
        ],
        "properties": {
          "completeSetCount": {
            "type": "string"
          },
          "graduatedAt": {
            "type": "string"
          },
          "graduationThreshold": {
            "type": "string"
          },
          "matchedMarketCap": {
            "type": "string"
          },
          "noTokens": {
            "type": "string"
          },
          "receiptCount": {
            "type": "string"
          },
          "refundedCollateral": {
            "type": "string"
          },
          "totalEscrowed": {
            "type": "string"
          },
          "yesTokens": {
            "type": "string"
          }
        }
      },
      "ManualAiReviewAlreadyReviewed": {
        "type": "object",
        "required": [
          "aiReview",
          "message",
          "status"
        ],
        "properties": {
          "aiReview": {
            "$ref": "#/components/schemas/MarketAiReview"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "already_reviewed"
            ]
          }
        }
      },
      "ManualAiReviewConflict": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/ManualAiReviewAlreadyReviewed"
          },
          {
            "$ref": "#/components/schemas/ManualAiReviewIneligible"
          }
        ]
      },
      "ManualAiReviewEnqueued": {
        "type": "object",
        "required": [
          "job",
          "status"
        ],
        "properties": {
          "job": {
            "$ref": "#/components/schemas/MarketAiReviewJob"
          },
          "status": {
            "type": "string",
            "enum": [
              "enqueued"
            ]
          }
        }
      },
