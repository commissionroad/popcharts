{
  "name": "popcharts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.10"
  },
  "scripts": {
    "setup": "pnpm install --frozen-lockfile && cd server && bun install --frozen-lockfile",
    "dev": "pnpm --dir app dev",
    "app:dev": "pnpm --dir app dev",
    "app:build": "pnpm --dir app build",
    "app:check": "pnpm --dir app format:check && pnpm --dir app lint && pnpm --dir packages/api-client api:check && pnpm --dir app typecheck && pnpm --dir app test:unit",
    "app:test": "pnpm --dir app test:unit",
    "app:coverage": "pnpm --dir app test:coverage",
    "app:e2e": "pnpm --dir app test:e2e",
    "app:e2e:smoke": "pnpm --dir app test:e2e:smoke",
    "app:e2e:chain": "pnpm --dir app test:e2e:chain",
    "devchain:deploy": "pnpm --dir protocol devchain:deploy",
    "devchain:e2e": "node --experimental-strip-types scripts/run-local-chain-e2e.ts",
    "protocol:build": "pnpm --dir protocol build",
    "protocol:check": "pnpm --dir protocol format:check && pnpm --dir protocol lint:sol && pnpm --dir protocol typecheck && pnpm --dir protocol test",
    "protocol:test": "pnpm --dir protocol test",
    "protocol:coverage": "pnpm --dir protocol test:coverage",
    "server:install": "cd server && bun install",
    "server:dev": "cd server && bun run dev",
    "server:api": "cd server && bun run dev:api",
    "server:indexer": "cd server && bun run dev:indexer",
    "server:ai-review-smoke": "cd server && bun run smoke:ai-review-runner",
    "server:check": "cd server && bun run format:check && bun run lint && bun run typecheck && bun run openapi:check && bun test",
    "server:coverage": "cd server && bun run test:coverage",
    "local:dev": "node --experimental-strip-types scripts/local-dev.ts",
    "local:dev:control": "node --experimental-strip-types scripts/local-dev-control.ts",
    "local:dev:ai-review": "node --experimental-strip-types scripts/local-dev.ts",
    "local:ai-review": "node --experimental-strip-types scripts/local-dev.ts --ai-review-only",
    "local:bot-trade": "cd server && bun run bot:trade",
    "local:create-market": "node --experimental-strip-types scripts/local-create-market.ts",
    "local:reset": "node --experimental-strip-types scripts/local-reset.ts",
    "local:lifecycle-nightly": "node --experimental-strip-types scripts/local-lifecycle-nightly.ts",
    "local:smoke": "node --experimental-strip-types scripts/local-chain-smoke.ts",
    "local:ai-review-smoke": "node --experimental-strip-types scripts/local-ai-review-smoke.ts",
    "local:deploy-venue": "pnpm --dir protocol run local:deploy-venue",
    "local:deploy-postgrad": "pnpm --dir protocol run local:deploy-postgrad",
    "local:create-complete-set-market": "pnpm --dir protocol run local:create-complete-set-market",
    "local:market-health": "pnpm --dir protocol run local:check-health",
    "local:market-smoke": "pnpm --dir protocol run local:smoke-market",
    "scripts:check": "tsc -p scripts && pnpm run scripts:test",
    "scripts:test": "node --experimental-strip-types --test \"scripts/test/*.test.ts\"",
    "test": "pnpm run app:test && pnpm run protocol:test && pnpm run scripts:test && cd server && bun test",
    "test:coverage": "pnpm run app:coverage && pnpm run protocol:coverage && pnpm run server:coverage",
    "check": "pnpm run app:check && pnpm run protocol:check && pnpm run server:check && pnpm run scripts:check",
    "format": "pnpm --dir app format && pnpm --dir protocol format",
    "format:check": "pnpm --dir app format:check && pnpm --dir protocol format:check"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
