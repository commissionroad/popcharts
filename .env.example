# Pop Charts environment template.
#
# The default non-local app chain is Arc Testnet. Market data stays
# fixture-backed unless an indexer API is configured.

NEXT_PUBLIC_POPCHARTS_CHAIN_ENV=arc-testnet
NEXT_PUBLIC_POPCHARTS_MARKET_CREATION_MODE=mock
NEXT_PUBLIC_POPCHARTS_MARKET_CREATION_SIGNER=wallet
NEXT_PUBLIC_POPCHARTS_CHAIN_ID=5042002
NEXT_PUBLIC_POPCHARTS_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_POPCHARTS_PREGRAD_MANAGER_ADDRESS=
NEXT_PUBLIC_POPCHARTS_COLLATERAL_ADDRESS=
NEXT_PUBLIC_POPCHARTS_ENABLE_LOCAL_CHAIN=false
NEXT_PUBLIC_POPCHARTS_ENABLE_LOCAL_WALLET=false

# Server-side preview/local devchain market creation. Never expose this key via
# NEXT_PUBLIC_* and never enable devchain writes in production.
POPCHARTS_DEVCHAIN_ENABLED=false
POPCHARTS_DEVCHAIN_PRIVATE_KEY=

# Optional server-side hook for market drafts submitted from the create flow.
# When set, the app forwards review tickets here for an AI review worker.
POPCHARTS_MARKET_REVIEW_WEBHOOK_URL=

# Arc Testnet deployment script inputs.
POPCHARTS_RPC_URL=https://rpc.testnet.arc.network
POPCHARTS_DEPLOYER_PRIVATE_KEY=
POPCHARTS_DEPLOYMENT_FILE=
POPCHARTS_APP_ENV_FILE=
POPCHARTS_WRITE_APP_ENV=true

# Server defaults live in server/sample.env. Copy that file to server/.env for
# local API/indexer development.
